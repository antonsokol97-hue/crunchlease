---
import BaseLayout from './BaseLayout.astro';
import Faq from '../components/Faq.astro';
import { SITE_NAME, DOMAIN } from '../config';
import { buildBreadcrumbListLd, buildWebApplicationLd } from '../lib/seo';
import type { FaqEntry } from '../lib/types';

interface Props {
  /** Document <title> — the 50–60 char meta title (SPEC.md §8). */
  title: string;
  /** Page <h1> — natural phrasing containing the primary keyword. Defaults to `title`. */
  heading?: string;
  description: string;
  /** Tool slug without leading/trailing slashes, e.g. "load-factor-calculator". */
  slug: string;
  breadcrumbLabel?: string;
  faqEntries?: FaqEntry[];
  /**
   * Force embed mode. When omitted, falls back to `?embed=1` on the current
   * URL — see SPEC.md §3. Embed mode strips header/footer/content down to
   * just the calculator, adds noindex, and appends a dofollow credit line.
   */
  embed?: boolean;
}

const { title, heading = title, description, slug, breadcrumbLabel = heading, faqEntries = [], embed: embedProp } =
  Astro.props;

const isEmbed = embedProp ?? Astro.url.searchParams.get('embed') === '1';
const canonicalUrl = new URL(`/${slug}/`, DOMAIN).toString();

const webAppLd = buildWebApplicationLd({ name: heading, description, url: canonicalUrl });
const breadcrumbLd = buildBreadcrumbListLd([
  { name: 'Home', url: DOMAIN },
  { name: breadcrumbLabel, url: canonicalUrl },
]);
const faqLd = faqEntries.length > 0 ? faqEntries : null;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} noindex={isEmbed} bare={isEmbed}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(webAppLd)} />
  {!isEmbed && <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}

  {
    isEmbed ? (
      <main class="tool-embed p-4">
        <slot name="calculator" />
        <p class="mt-3 text-xs" style={{ color: 'var(--color-text-muted)' }}>
          {/* Intentionally dofollow — no rel="nofollow"/"sponsored" (SPEC.md §3). */}
          Calculator by <a href={canonicalUrl}>{SITE_NAME}</a>
        </p>
      </main>
    ) : (
      <main class="tool-page mx-auto max-w-3xl px-4 py-8">
        {/* TODO(SPEC.md §3): add the Category crumb (Home → Category → Tool) once the
            category hub pages exist in Wave 3; linking now would 404. */}
        <nav aria-label="Breadcrumb" class="text-sm" style={{ color: 'var(--color-text-muted)' }}>
          <a href="/">Home</a> / <span>{breadcrumbLabel}</span>
        </nav>
        <h1 class="mt-2 text-2xl font-bold">{heading}</h1>
        <div class="mt-6">
          <slot name="calculator" />
        </div>
        <div class="mt-8">
          <slot name="content" />
        </div>
        {faqLd && <Faq items={faqLd} />}
        <div class="mt-8">
          <slot name="related" />
        </div>
      </main>
    )
  }
</BaseLayout>

{
  isEmbed && (
    <script>
      // Responsive iframe support: notify the parent frame of our content
      // height on load and on resize (SPEC.md §4.4).
      const sendHeight = () =>
        window.parent.postMessage({ type: 'cre-calc-embed-height', height: document.documentElement.scrollHeight }, '*');
      window.addEventListener('load', sendHeight);
      new ResizeObserver(sendHeight).observe(document.body);
    </script>
  )
}
