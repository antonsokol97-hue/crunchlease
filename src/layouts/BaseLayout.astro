---
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/600.css';
import '@fontsource/dm-sans/700.css';
import '@fontsource/plus-jakarta-sans/600.css';
import '@fontsource/plus-jakarta-sans/700.css';
import '../styles/global.css';
import { SITE_NAME, DOMAIN } from '../config';
import { buildOrganizationLd, buildWebSiteLd } from '../lib/seo';
import RentUnitToggle from '../components/RentUnitToggle.tsx';
import ConsentBanner from '../components/ConsentBanner.tsx';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  /** OG/Twitter image path (absolute-ised against DOMAIN). Placeholder shell — see C.3. */
  ogImage?: string;
  /** Adds <meta name="robots" content="noindex"> — used for embed routes (SPEC.md §3). */
  noindex?: boolean;
  /** Suppresses sitewide header/footer chrome — used for embed routes. */
  bare?: boolean;
}

const { title, description = '', canonicalUrl, ogImage = '/og-default.svg', noindex = false, bare = false } =
  Astro.props;

const websiteLd = buildWebSiteLd();
const organizationLd = buildOrganizationLd();
const ogImageUrl = new URL(ogImage, DOMAIN).toString();
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* Open Graph / Twitter (SPEC.md §8). Uses a placeholder OG image until the
        per-tool template art lands (C.3). */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- TODO(owner): Search Console verification meta tag (SPEC.md §8). -->
    <meta name="google-site-verification" content="TODO" />

    {/* GA4 loads only after consent and only when GA_MEASUREMENT_ID is set —
        see ConsentBanner + lib/analytics (SPEC.md §10). */}

    {!bare && <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteLd)} />}
    {!bare && <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationLd)} />}
  </head>
  <body>
    {
      !bare && (
        <header class="site-header flex items-center justify-between gap-4">
          <a href="/" class="text-lg font-semibold">
            {SITE_NAME}
          </a>
          <RentUnitToggle client:load />
        </header>
      )
    }

    <slot />

    {
      !bare && (
        <footer class="site-footer">
          <p>
            &copy; {new Date().getFullYear()} {SITE_NAME}. All calculations are estimates, not financial or legal
            advice.
          </p>
        </footer>
      )
    }

    {!bare && <ConsentBanner client:load />}
  </body>
</html>
